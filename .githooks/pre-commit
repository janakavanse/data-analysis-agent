#!/usr/bin/env bash
# Harness guards: never commit a secret; spec and code must always reconcile.
# Enable once:  git config core.hooksPath .githooks
set -euo pipefail

staged=$(git diff --cached --name-only --diff-filter=ACM || true)
[ -z "$staged" ] && exit 0

# 1) never commit a .env or a provider key
if echo "$staged" | grep -qE '(^|/)\.env$|\.env\.local$'; then
  echo "BLOCKED: a .env file is staged — secrets must never be committed."; exit 1
fi
patterns='sk-ant-[A-Za-z0-9_-]{20,}|AIza[0-9A-Za-z_-]{20,}|AQ\.[A-Za-z0-9_.-]{20,}|ghp_[A-Za-z0-9]{20,}|sk-[A-Za-z0-9]{32,}|eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}'
while IFS= read -r f; do
  [ -f "$f" ] || continue
  if git show ":$f" | grep -nEq "$patterns"; then echo "BLOCKED: possible secret in $f"; exit 1; fi
done <<< "$staged"

# 2) spec <-> code must reconcile when capability/code/tests change (the harness's core invariant)
if echo "$staged" | grep -qE '^(agent/|spec/capabilities/|tests/)' && [ -x .venv/bin/python ] && [ -f agent/analyze.py ]; then
  .venv/bin/python -m agent.analyze >/dev/null 2>&1 \
    || { echo "BLOCKED: spec and code do not reconcile — run 'make analyze' and fix before committing."; exit 1; }
fi

echo "pre-commit: secrets clean + spec↔code reconciled ✓"
exit 0
