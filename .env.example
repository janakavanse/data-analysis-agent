# Data Analyst Agent — Environment Variables
# Copy this file to .env and fill in your values.
# The .env file is gitignored and must never be committed.

# SQLite database file path (session + dataset metadata — not raw CSV rows)
AGENT_DATABASE_URL=sqlite:///./data/agent.db

# Google Gemini API key — required (https://aistudio.google.com/app/apikey)
AGENT_GEMINI_API_KEY=

# LLM model to use — defaults to gemini-2.5-flash (recommended for tabular Q&A)
# AGENT_LLM_MODEL=gemini-2.5-flash

# FastAPI server port
PORT=8001
