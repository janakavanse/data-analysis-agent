AGENT_DATABASE_URL=sqlite:///./data/agent.db

# LLM provider — auto-detected from whichever key is set below.
# This agent uses Gemini. Override explicitly: anthropic | gemini
# AGENT_LLM_PROVIDER=gemini

# Override model (uses provider default when blank).
# This agent's default is gemini-2.5-flash.
# AGENT_LLM_MODEL=gemini-2.5-flash

# Set exactly ONE provider key. For this agent, set the Gemini key:
AGENT_ANTHROPIC_API_KEY=
AGENT_GEMINI_API_KEY=

# DuckDB analytical engine (user-data) — in-process, local file.
# AGENT_DUCKDB_PATH=./data/analytics.duckdb
# AGENT_SAMPLE_ROW_COUNT=5
# AGENT_RESULT_ROW_CAP=1000

PORT=8001
