AGENT_DATABASE_URL=sqlite:///./data/agent.db

# LLM provider — Gemini is the chosen provider for this agent (cost-conscious).
# Auto-detected from whichever key is set below; set explicitly to be safe:
AGENT_LLM_PROVIDER=gemini

# Model — cheap default. Leave AGENT_LLM_MODEL blank to use gemini-2.5-flash.
# AGENT_LLM_MODEL=gemini-2.5-flash   (cheap default; leave blank to use it)

# Set the Gemini key (the only provider key this agent needs):
AGENT_GEMINI_API_KEY=
# Alternative provider (unused by default):
# AGENT_ANTHROPIC_API_KEY=

PORT=8001
