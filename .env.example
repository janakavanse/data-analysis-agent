# .env.example — copy to .env and fill in values
# The researcher will tell you which variables your project needs at intake.
# Never commit .env to git.

# ── LLM ────────────────────────────────────────────────────────────────────
APPNAME_LLM_PROVIDER=stub          # stub | openai | anthropic | gemini
APPNAME_LLM_MODEL=                 # leave blank to use provider default
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/appname
DATABASE_URL_TEST=postgresql+asyncpg://user:password@localhost:5432/appname_test

# ── App ─────────────────────────────────────────────────────────────────────
PORT=8001
APPNAME_ENV=development            # development | production
