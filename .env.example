# Environment variables for your agent
# Copy this file to .env and fill in the values.
#
# Real API keys are REQUIRED — tests and evals call the live LLM/API.
# Fill these in at intake before the build proceeds; this is the only manual step.
# .env is gitignored; never commit real keys.

# LLM provider — pick ONE at intake: openrouter | gemini | anthropic | other
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6          # a current model id for your provider

# Set the API key for your chosen provider (only the one you picked is needed):
OPENROUTER_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
# For "other": add your provider's key var + base URL here.

# Database (if needed)
# DATABASE_URL=

# The tech-architect adds agent-specific variables below after the spec and
# tech design are complete; the provider key above is not optional.
